{
    // Windows specific
    "security.allowedUNCHosts": [
        "wsl.localhost"
    ],
    "terminal.external.windowsExec": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
    "terminal.integrated.defaultProfile.windows": "PowerShell_7_5",
    "terminal.integrated.profiles.windows": {
        "PowerShell_7_5": {
            "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash",
            "icon": "terminal-git-bash"
        }
    },

    // Changes daily
    "chat.useAgentSkills": true,
    "chat.mcp.gallery.enabled": true,
    "chat.agent.maxRequests": 99999,
    "chat.viewSessions.orientation": "stacked",
    "chat.hookFilesLocations": {
        ".github/hooks": true,
        ".claude/settings.local.json": true,
        ".claude/settings.json": true,
        "~/.copilot/hooks": true,
        "~/.claude/settings.json": true,
        "~/.agents/hooks": true
    },
    "chat.instructionsFilesLocations": {
        ".github/instructions": true
    },
    "chat.tools.urls.autoApprove": {
        "https://learn.microsoft.com": {
            "approveRequest": false,
            "approveResponse": true
        }
    },
    "chat.autopilot.enabled": true,
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.chat.agentDebugLog.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },

    // chat diff features are so broken, this doesn't even have the ability to fix it all the way
    "workbench.colorCustomizations": {
        // --- Copilot/Inline diff-style edits (usually these) ---
        "diffEditor.insertedTextBackground": "#0f361055", // subdued green w/ alpha
        "diffEditor.removedTextBackground":  "#18020255", // subdued red  w/ alpha

        // Optional: soften borders if your theme draws them
        "diffEditor.insertedTextBorder": "#2E7D3200",
        "diffEditor.removedTextBorder":  "#18020255"
    },


    // Misc...
    "editor.inlayHints.enabled": "offUnlessPressed",
    "rust-analyzer.diagnostics.enable": false,
    "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "update.showReleaseNotes": false,
    "workbench.startupEditor": "none",
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.list.openMode": "doubleClick",
    "workbench.preferredHighContrastColorTheme": "Visual Studio 2017 Dark - C++",
    "workbench.preferredHighContrastLightColorTheme": "Visual Studio 2017 Light - C++",
    "workbench.tree.indent": 20,
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "java.import.generatesMetadataFilesAtProjectRoot": false,
    "editor.renderWhitespace": "none",
    "editor.detectIndentation": false,
    "redhat.telemetry.enabled": false,
    "editor.fontSize": 14,
    "database.connections": [],
    "explorer.autoReveal": "focusNoScroll",
    "editor.tabSize": 4,
    "editor.guides.indentation": false,
    "editor.folding": false,
    "git.openRepositoryInParentFolders": "never",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "javascript.updateImportsOnFileMove.enabled": "always",

    "files.autoSave": "off",
    
    // Formatting on save related... disabled soon (or now)
    "files.insertFinalNewline": false,
    "files.trimTrailingWhitespace": false,
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
        // "source.fixAll": "always",
        // "source.fixAll.ts": "always",
        // "source.fixAll.eslint": "always"
    },
    "eslint.format.enable": true,
    "eslint.validate": [
        "javascript",
        "javascriptreact"
    ],
    "eslint.quiet": false,
    "eslint.debug": true,
    "remove-tabs-on-save.ignoreFileExtensions": [
        "*.go",
        "go.mod",
        "go.sum"
    ],
    "editor.indentSize": "tabSize",
    "editor.inlineSuggest.enabled": true,
    "[plaintext]": {
        "editor.wordWrap": "on"
    },
    "[ruby]": {
        "editor.tabSize": 2
    },
    "[html]": {
        "editor.tabSize": 2,
        "editor.wordWrap": "on"
    },
    "[json]": {
        "editor.detectIndentation": true
    },
    "[erb]": {
        "editor.defaultFormatter": "aliariff.vscode-erb-beautify",
        "editor.wordWrap": "on",
        "editor.tabSize": 2,
        "editor.formatOnSave": true
    },
    "[go.mod]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": false,
        "editor.insertSpaces": false
    },
    "[javascript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint",
        // "editor.formatOnSave": true
    },
    "vscode-erb-beautify.executePath": "~/bin/htmlbeautifier",
    "vscode-erb-beautify.keepBlankLines": 2,
    "go.toolsManagement.autoUpdate": true,
    "cmake.configureOnOpen": false,
    "debug.openDebug": "neverOpen",
    "window.zoomLevel": 1,
    "jest.disabledWorkspaceFolders": [],
    "workbench.preferredDarkColorTheme": "Visual Studio Dark - C++",
    "window.autoDetectHighContrast": false,
    "editor.rulers": [
        80,
        100
    ],
    "editor.hover.hidingDelay": 50,
    "extensions.ignoreRecommendations": true,
    
    // "editor.unicodeHighlight.allowedCharacters": {
    //     "’": false
    // },
    "workbench.colorTheme": "Atom One Light2",
    "editor.accessibilitySupport": "off",
    "editor.stickyScroll.enabled": false,
    "cmake.showOptionsMovedNotification": false,
    "editor.copyWithSyntaxHighlighting": false,
    "stretchySpaces.excludedLanguages": [
        "markdown",
        "plaintext",
        "README.md",
        "README",
        "yml",
        "yaml",
        "md"
    ],
    "stretchySpaces.includedLanguages": [
        "javascript",
        "javascriptreact",
        "typescript"
    ],
    "stretchySpaces.updateDelay": 10,
    "python.analysis.includeAliasesFromUserFiles": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.packageIndexDepths": [
        {
            "name": "pipecat",
            "depth": 4
        },
        {
            "name": "sklearn",
            "depth": 2
        },
        {
            "name": "matplotlib",
            "depth": 2
        },
        {
            "name": "scipy",
            "depth": 2
        },
        {
            "name": "django",
            "depth": 2
        },
        {
            "name": "flask",
            "depth": 2
        },
        {
            "name": "fastapi",
            "depth": 2
        },
        {
            "name": "cuda",
            "depth": 3,
            "includeAllSymbols": true
        }
    ],
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            // Exact match for what the inspector shows now:
            "method.decorator": {
                "foreground": "#f133f7",
                "fontStyle": "bold"
            },
            // Useful if you also use free functions/classes as decorators:
            "function.decorator": {
                "foreground": "#f133f7",
                "fontStyle": "bold"
            },
            "class.decorator": {
                "foreground": "#f133f7",
                "fontStyle": "bold"
            },
            // Catch‑all: anything used as a decorator regardless of base type
            "*.decorator": {
                "foreground": "#f133f7"
            }
        }
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "entity.name.function.decorator.python",
                "settings": {
                    "foreground": "#f133f7"
                }
            },
            {
                "scope": "meta.function.decorator.python",
                "settings": {
                    "foreground": "#f133f7"
                }
            },
        ]
    },
    "html.format.wrapLineLength": 0,
    "editor.renderControlCharacters": false
}
