// Place your key bindings in this file to override the defaults
[
  // Reasonable ctrl + tab behavior
  {
    "key": "ctrl+tab",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+shift+tab",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+shift+h",
    "command": "workbench.action.previousEditor"
  },

  // global find is find and replace by default
  {
    "key": "ctrl+shift+f",
    "command": "-workbench.action.findInFiles"
  },
  {
    "key": "ctrl+shift+f",
    "command": "-workbench.view.search",
    "when": "workbench.view.search.active && neverMatch =~ /doesNotMatch/"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.replaceInFiles",
    "when": "!isSessionsWindow && !searchViewletFocus"
  },

  // fuzzy find with ctrl + t
  {
    "key": "cmd+t",
    "command": "-workbench.action.showAllSymbols"
  },
  {
    "key": "cmd+t",
    "command": "workbench.action.quickOpen"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.quickOpen"
  },

  // Save also clears annoying chat completions
  {
    "key": "cmd+s",
    "command": "runCommands",
    "args": {
      "commands": [
        {
          "command": "workbench.action.files.save"
        },
        {
          "command": "editor.action.inlineSuggest.hide"
        },
        {
          "command": "hideSuggestWidget"
        }
      ]
    },
    "when": "inInlineEditsPreviewEditor"
  },
  {
    "key": "ctrl+s",
    "command": "runCommands",
    "args": {
      "commands": [
        {
          "command": "workbench.action.files.save"
        },
        {
          "command": "editor.action.inlineSuggest.hide"
        },
        {
          "command": "hideSuggestWidget"
        }
      ]
    },
    "when": "inInlineEditsPreviewEditor"
  },

  // ??
  {
    "key": "cmd+2",
    "command": "-workbench.action.focusSecondEditorGroup"
  },

  // Copy file relative path
  {
    "key": "cmd+\\",
    "command": "copyRelativeFilePath"
  },
  {
    "key": "ctrl+\\",
    "command": "copyRelativeFilePath"
  },
  { // unbind default
    "key": "ctrl+\\",
    "command": "-workbench.action.splitEditor"
  },
  { // unbind default
    "key": "cmd+\\",
    "command": "-workbench.action.splitEditor"
  },

  // Windows / Linux, highlight active file in tree view (cause I disable defaults)
  {
    "key": "shift+ctrl+\\",
    "command": "workbench.files.action.showActiveFileInExplorer",
    "when": "editorTextFocus"
  },
  // Focus the editor if we're already switched to the explorer
  {
    "key": "shift+ctrl+\\",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "!editorTextFocus"
  },
  {
    "key": "shift+ctrl+\\",
    "command": "-editor.action.jumpToBracket",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+ctrl+\\",
    "command": "-workbench.action.terminal.focusTabs",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported || terminalHasBeenCreated && terminalTabsFocus || terminalProcessSupported && terminalTabsFocus"
  },

  // Mac, highlight active file in tree view (cause I disable defaults)
  {
    "key": "shift+cmd+\\",
    "command": "workbench.files.action.showActiveFileInExplorer"
  },
  {
    "key": "shift+cmd+\\",
    "command": "-editor.action.jumpToBracket",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+cmd+\\",
    "command": "-workbench.action.terminal.focusTabs",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported || terminalHasBeenCreated && terminalTabsFocus || terminalProcessSupported && terminalTabsFocus"
  },

  // Focus chat view
  {
    "key": "ctrl+alt+j",
    "command": "workbench.action.chat.open",
    "when": "!auxiliaryBarVisible || !chatInputHasFocus"
  },
  {
    "key": "ctrl+alt+j",
    "command": "workbench.action.toggleAuxiliaryBar",
    "when": "auxiliaryBarVisible && chatInputHasFocus"
  },

  // don't forget about ctrl + b to minimize the left sidebar!
  {
    "key": "ctrl+alt+b",
    "command": "workbench.action.toggleAuxiliaryBar"
  },

  // new chat
  {
    "key": "ctrl+alt+n",
    "command": "workbench.action.chat.newChat",
    "when": "auxiliaryBarVisible"
  },
  {
    "key": "ctrl+alt+n",
    "command": "runCommands",
    "args": {
      "commands": [
        {
          "command": "workbench.action.toggleAuxiliaryBar"
        },
        {
          "command": "workbench.action.chat.newChat"
        }
      ]
    },
    "when": "!auxiliaryBarVisible"
  },

  ///////////////////////
  // Editor Navigation //
  ///////////////////////

  // Jump to matching bracket
  {
    "key": "shift+ctrl+n",
    "command": "editor.action.jumpToBracket",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+ctrl+n",
    "command": "-workbench.action.newWindow"
  },
  {
    "key": "shift+ctrl+n",
    "command": "-chatEditor.action.reject"
  },

  // Jump to beginning/ end of html tag
  {
    "key": "ctrl+shift+;",
    "command": "editor.emmet.action.matchTag",
    "when": "editorTextFocus"
  },

  // Windows/ Linux, ctrl + r renames selected file or refactors a symbol
  {
    "key": "ctrl+r",
    "command": "editor.action.rename",
    "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+r",
    "command": "-inlineChat.regenerate",
    "when": "inlineChatHasProvider && inlineChatVisible"
  },
  {
    "key": "ctrl+r",
    "command": "-workbench.action.terminal.chat.rerunRequest",
    "when": "chatIsEnabled && terminalChatFocus && terminalHasBeenCreated && !terminalChatActiveRequest || chatIsEnabled && terminalChatFocus && terminalProcessSupported && !terminalChatActiveRequest"
  },
  {
    "key": "ctrl+r",
    "command": "renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },

  // Mac, cmd + r renames selected file or refactors a symbol
  {
    "key": "cmd+r",
    "command": "editor.action.rename",
    "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "cmd+r",
    "command": "-inlineChat.regenerate",
    "when": "inlineChatHasProvider && inlineChatVisible"
  },
  {
    "key": "cmd+r",
    "command": "-workbench.action.terminal.chat.rerunRequest",
    "when": "chatIsEnabled && terminalChatFocus && terminalHasBeenCreated && !terminalChatActiveRequest || chatIsEnabled && terminalChatFocus && terminalProcessSupported && !terminalChatActiveRequest"
  },
  {
    "key": "cmd+r",
    "command": "renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  }

]
